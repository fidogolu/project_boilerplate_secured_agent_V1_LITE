# =========================================================================
# 📊 LOGGING & DEBUG
# =========================================================================
LOG_LEVEL=INFO

# ===========================================
# 🤖 LLM SERVICE ENDPOINT
# Configure your LLM backend (OpenAI, Ollama, vLLM, etc.)
# ===========================================
WORKER_LLM_URL=http://localhost:8000/v1
WORKER_MODEL_NAME=your-model-name

# ===========================================
# 🔗 EXTERNAL SERVICE (MCP/API)
# Base URL for tool-calling services
# ===========================================
MCP_BASE_URL=http://localhost:8080

# ===========================================
# 🔒 SECURITY MODE
# Options: none | lite | full | remote
# ===========================================
SECURITY_MODE=lite
SECURITY_SERVICE_URL=

# Security thresholds (for semantic analysis modes)
SECURITY_TIMEOUT=30
SECURITY_THRESHOLD=0.5
SECURITY_INPUT_THRESHOLD=0.6
SECURITY_OUTPUT_THRESHOLD=0.6

# Security bypass — comma-separated categories to skip (empty = block all)
SECURITY_BYPASS_CATEGORIES=

# ===========================================
# 📊 OBSERVABILITY
# Tracing & monitoring (Langfuse, LangSmith, etc.)
# ===========================================
OBSERVABILITY_HOST=http://localhost:3000
OBSERVABILITY_PUBLIC_KEY=your_observability_key
OBSERVABILITY_SECRET_KEY=your_observability_secret

# ===========================================
# 📊 APPLICATION
# ===========================================
APP_TEMP_DIR=./temp_data
MAX_MESSAGE_LENGTH=4096
MAX_CONVERSATION_HISTORY=50
